# Public checkout target. Use a Gumroad, Lemon Squeezy, Ko-fi, Buy Me a Coffee,
# Stripe Checkout payment link, or leave empty to show the manual checkout form.
NEXT_PUBLIC_PAYMENT_LINK=

# Public support/contact email shown on the site.
NEXT_PUBLIC_SUPPORT_EMAIL=you@example.com

# Optional PayPal email for manual MVP payments. Only set this if the email can be public.
NEXT_PUBLIC_PAYPAL_EMAIL=

# Automated PayPal Checkout. Use sandbox credentials until you have tested end-to-end.
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
NEXT_PUBLIC_PAYPAL_CURRENCY=USD
NEXT_PUBLIC_PRICE_SOLO=9.00
NEXT_PUBLIC_PRICE_BUNDLE=19.00
NEXT_PUBLIC_PRICE_TEAM=39.00

# Required for automatic paid unlock codes. Generate a long random value and keep it secret.
LICENSE_SIGNING_SECRET=

# Optional manual payment instruction shown on checkout.
NEXT_PUBLIC_PAYMENT_INSTRUCTIONS="Pay with PayPal Goods and Services, then submit the receipt reference below."

# Comma-separated SHA-256 hashes of valid unlock codes for production.
# Generate with: node -e "console.log(require('crypto').createHash('sha256').update('YOUR-CODE').digest('hex'))"
LICENSE_CODE_HASHES=

# Keep false in production. In local dev/test, DEMO-FULL-ACCESS is accepted automatically.
ALLOW_DEMO_LICENSE=false
